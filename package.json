{
  "name": "rugbylive",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "apps/api/**/*.java": [
      "bash -c 'mvn -f apps/api/pom.xml checkstyle:check'"
    ],
    "apps/app/**/*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}